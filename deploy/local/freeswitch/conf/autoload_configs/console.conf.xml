<?xml version="1.0"?>
<configuration name="console.conf" description="Console Logger">
  <mappings>
    <map name="all" value="console,info,warning,err,crit,alert"/>
  </mappings>
  <settings>
    <param name="colorize" value="true"/>
    <param name="loglevel" value="info"/>
  </settings>
</configuration>
