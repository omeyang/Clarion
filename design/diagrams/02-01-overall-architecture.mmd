flowchart TB
    subgraph L1["1. 用户交互层"]
        Admin["管理后台（未来 Web UI）<br/>任务管理 / 联系人管理<br/>模板管理 / 通话查询"]
        WeCom["企业微信通知<br/>高优联系人推送<br/>任务结果 / 异常提醒"]
    end

    subgraph L2["2. 业务编排层"]
        API["Go HTTP API Server<br/>net/http 标准库路由<br/>handler → service → store"]
    end

    subgraph L3["3. 实时会话运行时"]
        CW["Call Worker 进程<br/>Asynq 任务消费<br/>Session 编排 / 双状态机<br/>WebSocket 音频服务"]
        PP["Post-Processor 进程<br/>Redis Stream XReadGroup<br/>摘要 / 商机提取 / 落库 / 通知"]
    end

    subgraph L4["4. 通信控制层"]
        FS["FreeSWITCH<br/>ESL 控制 / SIP 管理<br/>mod_audio_fork 音频流<br/>录音 / 会话事件"]
        Callee["被叫联系人"]
    end

    subgraph L5["5. AI 能力层（Go 接口 aiface）"]
        ASR["ASR Provider<br/>云端: 通义听悟 Qwen ASR<br/>本地: sherpa-onnx Paraformer<br/>混合: RacingASR 竞速"]
        LLM["LLM Provider<br/>DeepSeek（SSE 流式）"]
        TTS["TTS Provider<br/>云端: DashScope CosyVoice<br/>本地: sherpa-onnx VITS<br/>混合: TieredTTS 分层"]
        RT["Realtime Provider<br/>Qwen3-Omni-Flash-Realtime<br/>（混合管线模式）"]
    end

    subgraph L6["6. 数据存储层"]
        PG["PostgreSQL（pgx/v5）<br/>联系人 / 任务 / 通话 / 模板"]
        Redis["Redis（go-redis/v9）<br/>Asynq 队列 / Stream 事件<br/>会话快照 / 分布式锁"]
    end

    Admin --> API
    WeCom <--> PP
    API -->|"Asynq 任务派发"| Redis
    CW -->|"Asynq 消费任务"| Redis
    CW <-->|"ESL + WebSocket"| FS
    FS <--> Callee
    CW --> ASR
    CW --> LLM
    CW --> TTS
    CW -.->|"混合模式"| RT
    CW -->|"Redis Stream XADD"| Redis
    PP -->|"XReadGroup 消费"| Redis
    PP --> PG
    API <--> PG
