flowchart TB
    subgraph MGMT["API Server（bin/clarion）"]
        R["api/router.go<br/>HTTP 路由"]
        H["api/handler/<br/>请求处理"]
        S["api/schema/<br/>请求/响应 Schema"]
        MW["api/middleware.go<br/>日志 / Recovery"]
        SVC["service/<br/>业务逻辑"]
        ST["store/<br/>数据访问（pgx/v5）"]
    end

    subgraph CW["Call Worker（bin/clarion-worker）"]
        WK["call/worker.go<br/>Asynq Handler / WS Server"]
        SESS["call/session.go<br/>Session 编排"]
        ESL["call/esl/<br/>FreeSWITCH ESL"]
        AMD["call/amd/<br/>应答机检测"]
        MFSM["engine/media/fsm.go<br/>Media FSM"]
        DENG["engine/dialogue/<br/>Dialogue FSM"]
        RENG["engine/rules/<br/>规则引擎"]
        GD["guard/<br/>安全防护链<br/>预算/校验/安全/跑题"]
        RS["resilience/<br/>熔断/重试/降级"]
        PC["precompile/<br/>预编译"]
        OB["observe/<br/>可观测性"]
    end

    subgraph POST["Post-Processor（bin/clarion-postprocessor）"]
        PW["postprocess/worker.go<br/>Redis Stream 消费"]
        SM["postprocess/summary.go<br/>LLM 摘要"]
        OP["postprocess/opportunity.go<br/>商机提取"]
        WR["postprocess/writer.go<br/>PostgreSQL 写入"]
        NT["notify/<br/>企业微信通知"]
    end

    subgraph PROV["Provider 实现"]
        QASR["provider/asr/qwen.go<br/>通义听悟 ASR"]
        DLM["provider/llm/deepseek.go<br/>DeepSeek LLM"]
        DTTS["provider/tts/dashscope.go<br/>DashScope CosyVoice"]
        POOL["provider/tts/pool.go<br/>WS 连接池"]
        OMNI["provider/realtime/omni.go<br/>Qwen3-Omni-Realtime"]
        STRT["provider/strategy/smart.go<br/>Smart Strategy"]
    end

    subgraph SONATA["Sonata 核心库"]
        ESESS["engine/session.go"]
        ETRANS["engine/transport.go"]
        AIFACE["engine/aiface/<br/>ASR/LLM/TTS 接口"]
        EPCM["engine/pcm/<br/>音频处理"]
        SASR["sherpa/asr.go<br/>Paraformer"]
        STTS["sherpa/tts.go<br/>VITS"]
        SVAD["sherpa/vad.go<br/>Silero VAD"]
        SRACE["sherpa/raceasr.go<br/>RacingASR"]
        STIER["sherpa/tieredtts.go<br/>TieredTTS"]
        SSPK["sherpa/speaker.go<br/>说话人嵌入"]
