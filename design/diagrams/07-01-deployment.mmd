flowchart LR
    Admin["管理后台"] --> App

    subgraph Host["Linux Server"]
        subgraph Compose["Podman Compose"]
            PG["PostgreSQL"]
            Redis["Redis"]
        end
        App["bin/clarion<br/>API Server<br/>Go net/http"]
        CW["bin/clarion-worker<br/>Call Worker<br/>Asynq + ESL + WS"]
        PP["bin/clarion-postprocessor<br/>Post-Processor<br/>Redis Stream"]
        FS["FreeSWITCH<br/>ESL / SIP / mod_audio_fork"]
        SHERPA["sherpa-onnx 本地推理（可选）<br/>Paraformer ASR / VITS TTS<br/>Silero VAD"]
    end

    subgraph External["外部依赖"]
        AI["通义听悟 ASR（WebSocket）<br/>DeepSeek LLM（SSE）<br/>DashScope CosyVoice TTS（WebSocket）"]
        WeCom["企业微信"]
        Tel["电话线路（SIP trunk）"]
    end

    App <--> PG
    App <--> Redis
    CW <--> Redis
    PP <--> Redis
    PP --> PG
    PP --> WeCom
    CW <--> FS
    FS <--> Tel
    CW <--> AI
    CW -.-> SHERPA

    subgraph OBS["可观测性（可选）"]
        OTEL["OTel 指标<br/>通话时长 / 延迟 / 抖动"]
        EBPF["eBPF 追踪<br/>TCP / 调度延迟<br/>需 CAP_BPF"]
    end

    CW -.-> OBS

    SKIP["当前不做<br/>Kubernetes / 多机高可用<br/>服务网格 / 微服务拆分"]
    SKIP -.-> Host
