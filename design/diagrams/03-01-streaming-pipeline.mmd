flowchart LR
    FS["FreeSWITCH<br/>8kHz PCM 音频流"] --> RESAMPLE["重采样<br/>8kHz → 16kHz<br/>pcm.Resample8to16Into"]
    RESAMPLE --> VAD["SpeechDetector<br/>WebRTC/Silero VAD<br/>能量阈值回退"]

    VAD -->|"语音开始"| ASR["流式 ASR<br/>partial → final<br/>↓ 跟踪 partial 稳定性"]
    VAD -->|"静默超时"| TIMEOUT["静默处理<br/>首次 6s 提醒<br/>二次 15s 挂断"]

    ASR -->|"partial 稳定 ≥3 次"| SPEC["预推理<br/>PrepareStream<br/>提前启动 LLM"]
    ASR -->|"final 结果"| FILLER["播放填充词<br/>预合成 PCM<br/>轮询选择<br/>~200ms"]

    FILLER --> MATCH{"final 与<br/>预推理匹配?"}
    MATCH -->|"匹配: commit"| TTS
    MATCH -->|"不匹配: cancel"| LLM
    SPEC -.->|"sentenceCh"| MATCH

    LLM["DialogueEngine<br/>ProcessStream<br/>返回 chan string"] -->|"逐句输出"| TTS["流式 TTS<br/>synthesizeAndPlay<br/>StreamAsync<br/>逐句独立合成"]

    TTS -->|"音频块"| PLAY["回送 AudioOut<br/>→ WebSocket<br/>→ FreeSWITCH"]

    PLAY -.->|"用户打断<br/>连续 10 帧 ≈ 200ms"| STOP["Barge-in<br/>ttsCancel()<br/>uuid_break<br/>重置 ASR"]
    STOP --> VAD

    style VAD fill:#f9f,stroke:#333
    style TIMEOUT fill:#fcc,stroke:#333
    style STOP fill:#fcc,stroke:#333
    style FILLER fill:#ffd,stroke:#333
    style SPEC fill:#dff,stroke:#333
