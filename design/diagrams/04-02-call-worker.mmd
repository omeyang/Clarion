flowchart TB
    REDIS["Redis 任务队列"]
    REDIS -->|"取外呼任务"| CW

    subgraph CW["Call Worker 进程"]
        direction TB
        ESL_CONN["ESL 连接<br/>发起外呼 / 接收事件"]
        WS_CONN["WebSocket 连接<br/>音频收发"]

        subgraph MEDIA["媒体层"]
            RESAMPLE["音频重采样"]
            VAD_MOD["VAD 检测"]
            ECHO["回声抑制标记"]
        end

        subgraph STREAM["流式管道"]
            S_ASR["流式 ASR"]
            S_LLM["流式 LLM"]
            S_TTS["流式 TTS"]
            CACHE["预合成音频缓存"]
        end

        MSM["媒体状态机<br/>BOT_SPEAKING<br/>WAITING_USER<br/>USER_SPEAKING<br/>PROCESSING<br/>BARGE_IN"]
        BSM["业务状态机<br/>Opening<br/>Qualification<br/>InformationGathering<br/>..."]

        PROTECT["通话保护<br/>超时/降级/最大时长"]
    end

    CW -->|"通话完成事件<br/>原始对话数据"| REDIS2["Redis 事件流"]
    REDIS2 --> PP["Post-Processing<br/>Worker"]

    ESL_CONN <--> FS["FreeSWITCH"]
    WS_CONN <--> FS
