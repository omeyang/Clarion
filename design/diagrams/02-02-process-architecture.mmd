flowchart LR
    subgraph MGMT["API Server（HTTP 管理面）"]
        A1["api/router.go<br/>路由注册"]
        A2["api/handler/<br/>请求处理"]
        A3["service/<br/>业务逻辑"]
        A4["store/<br/>数据访问"]
    end

    subgraph RT["Call Worker 通话面（可多实例）"]
        B1["FreeSWITCH<br/>ESL + WebSocket"]
        B2["Media FSM<br/>媒体状态机"]
        B3["流式管道<br/>VAD→ASR→LLM→TTS"]
        B4["Dialogue FSM<br/>对话状态机"]
    end

    subgraph POST["Post-Processor 后处理面"]
        C1["摘要生成<br/>summary.go"]
        C2["商机提取<br/>opportunity.go"]
        C3["结果写入 PostgreSQL<br/>writer.go"]
        C4["企业微信通知<br/>notify/"]
    end

    Q["Redis<br/>Asynq 任务队列 / Stream 事件流"]

    MGMT -->|"Asynq 派发外呼任务"| Q
    Q -->|"Asynq 消费任务"| RT
    RT -->|"Stream XADD 通话完成事件"| Q
    Q -->|"XReadGroup 消费事件"| POST
